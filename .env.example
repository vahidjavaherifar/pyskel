##################################################
# 1. APPLICATION
##################################################

# The formal name of the application
APP_NAME="My App"

# A URL-friendly version of the app name (Slug)
APP_SLUG=my-app

# Current versioning of the application (SemVer)
APP_VERSION=0.1.0

# The operational environment mode
# Options: development, staging, production, testing, profiling
APP_ENV=development

# The regional formatting standard for the application
APP_LOCALE=en_US

# The global timezone reference for the entire system stack
APP_TIMEZONE=UTC

# Toggle comprehensive error reporting and development tools
# WARNING: Must be 'false' in production to prevent information disclosure
APP_DEBUG=true

# A unique, secret key used for cryptography and session signing
# SECURITY: Keep this value private and rotate regularly
APP_SECRET_KEY=YOUR-APP-SECRET-KEY


##################################################
# 2. SERVER & NETWORKING
##################################################

# The network interface the server binds to (e.g., 0.0.0.0)
SERVER_HOST=0.0.0.0

# Internal port the application listens on inside its environment
SERVER_CONTAINER_PORT=8000

# External port used by the host machine to access the service
SERVER_HOST_PORT=8000

# Number of concurrent worker processes (e.g., (2 x CPU cores) + 1)
SERVER_WORKERS=4

# Comma-separated list of domains or IPs allowed to access the application
SERVER_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Force secure (HTTPS) connections for cookies and redirects
# WARNING: Set to 'true' only if SSL/TLS is handled by the app or proxy
SERVER_ENABLE_HTTPS=false


##################################################
# 3. API
##################################################

# The global prefix for all API endpoints (e.g., /api/v1)
API_V1=/api/v1

# Project documentation URLs (Set to empty to disable in production)
API_SWAGGER_URL=/docs
API_REDOC_URL=/redoc

# Comma-separated list of origins allowed to make Cross-Origin requests
# Use '*' for public access or comma-separated URLs for restricted access
API_CORS=http://localhost:3000,https://myapp.com

# Maximum number of requests allowed in a standard window (e.g., per minute)
API_RATE_LIMIT=60

# Maximum number of concurrent requests allowed in a sudden spike
API_BURST_LIMIT=10


##################################################
# 4. AUTHENTICATION
##################################################

# Filesystem paths to the RSA keys for asymmetric signing
AUTH_PRIVATE_KEY=/app/secrets/jwt_private.pem
AUTH_PUBLIC_KEY=/app/secrets/jwt_public.pem

# Cryptographic algorithm used for token signing (e.g., RS256, HS256)
AUTH_ALGORITHM=RS256

# Duration in minutes for access token validity
AUTH_ACCESS_EXPIRE=15

# Duration in days for refresh token validity
AUTH_REFRESH_EXPIRE=30

# Computational cost factor for BCrypt hashing
AUTH_PASSWORD_SALT_ROUNDS=12


##################################################
# 5. CACHE
##################################################

# Connection string for the primary caching service
CACHE_URL=redis://:password@redis:6379/0

# Default time-to-live (TTL) for cached data in seconds
CACHE_TTL=86400

# Optional prefix for cache keys to prevent namespace collisions
CACHE_PREFIX=myapp_


##################################################
# 6. MESSAGE BROKER
##################################################

# Connection string for the message broker (Task Queue)
BROKER_URL=redis://redis:6379/1

# Connection string for storing task execution results
BROKER_RESULT_BACKEND=redis://redis:6379/1

# Toggle late acknowledgement to ensure task reliability
# If 'true', tasks are only removed from queue after successful completion
BROKER_ACK_LATE=true


##################################################
# 7. DATABASE
##################################################

# Primary connection string (Constructed from parameters or provided directly)
# Format: engine://user:password@host:port/dbname
DB_URL=postgresql://user:password@db:5432/myapp

# The database management system engine/dialect
DB_ENGINE=postgresql

# Database server hostname or internal service name
DB_HOST=db

# Port number on which the database server is listening
DB_PORT=5432

# Name of the specific database to connect to
DB_NAME=myapp

# Username for database authentication
DB_USERNAME=admin

# Password for database authentication
DB_PASSWORD=YOUR-DB-PASSWORD

# Specific database schema to use
DB_SCHEMA=public

# Number of persistent connections maintained in the pool
DB_POOL_SIZE=10

# Maximum number of transient connections beyond DB_POOL_SIZE
DB_MAX_OVERFLOW=20

# Time (seconds) after which a connection is automatically recycled
DB_POOL_RECYCLE=3600

# Maximum time (seconds) to wait for a connection before timing out
DB_TIMEOUT=30

# Toggle SQL query logging for debugging purposes
DB_LOG=true


##################################################
# 8. STORAGE
##################################################

# The storage driver to use (e.g., local, s3, minio)
STORAGE_DRIVER=s3

# The specific backend class (For dynamic loading in frameworks)
STORAGE_BACKEND=storages.backends.s3boto3.S3Boto3Storage

# Connection Credentials
STORAGE_ACCESS_KEY=YOUR-STORAGE-ACCESS-KEY
STORAGE_SECRET_KEY=YOUR-STORAGE-SECRET-KEY

# The specific bucket or container identifier
STORAGE_BUCKET=my-assets

# The service endpoint URL (Required for S3/MinIO-compatible providers)
STORAGE_ENDPOINT=https://s3.amazonaws.com
#
# The physical data center location (e.g., us-east-1, thr-at1)
STORAGE_REGION=us-east-1

# Toggle public accessibility of the storage bucket/files
STORAGE_PUBLIC=true

# Maximum allowed file size in bytes (e.g., 10MB)
STORAGE_MAX_SIZE=10485760


##################################################
# 9. EMAIL
##################################################

# The hostname of the outgoing SMTP server (e.g., smtp.gmail.com)
MAIL_SERVER=smtp.myapp.com

# The port number for the SMTP server (Common: 587 for TLS, 465 for SSL)
MAIL_PORT=587

# The username/email used for authenticating with the SMTP server
MAIL_USERNAME=username@myapp.com

# The password or app-specific token for SMTP authentication
MAIL_PASSWORD=YOUR-EMAIL-PASSWORD

# Enables STARTTLS encryption (Mandatory for most modern SMTP relay services)
MAIL_TLS=true

# Enables implicit SSL/TLS encryption (Required if using port 465)
MAIL_SSL=false

# The email address that will appear in the 'From' field of the message
MAIL_FROM=no-reply@myapp.com

# The display name associated with the sender email address
MAIL_NAME="My App"


##################################################
# 10. SMS
##################################################

# The authentication API key or token from your provider
SMS_API_KEY=YOUR-SMS-API-KEY

# The virtual line number or sender identity
SMS_NUMBER=+11000123456

# The specific template name for transactional/OTP messages
SMS_TEMPLATE=otp

# Toggle to 'true' to use the provider's fast/lookup delivery system
SMS_LOOKUP=true


##################################################
# 11. OBSERVABILITY
##################################################

# The unique identifier/address for error reporting
OBS_DSN=

# Percentage of transactions to trace (0.1 = 10%)
OBS_SAMPLE_RATE=0.1

# Toggle system metrics collection (CPU, Memory, etc.)
OBS_METRICS_ENABLED=true

# The endpoint for distributed request tracing (OTLP)
OBS_TRACING_ENDPOINT=http://telemetry-collector:4317


##################################################
# 12. LOG
##################################################

# Detail level for system logs
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# The structure of log output
# Options: TEXT, JSON
LOG_FORMAT=TEXT

# Toggle source code file and line numbers in log output
LOG_SOURCE=true


##################################################
# 13. INFRASTRUCTURE & RESOURCE
##################################################

# The unique identifier for this project instance in the infrastructure
INFRA_PROJECT_NAME=my_app

# The restart behavior in case of system or application failure
# Options: no, always, on-failure, unless-stopped
INFRA_RESTART_POLICY=unless-stopped

# CPU priority/shares for the application (Standard: 1024)
INFRA_CPU_WEIGHT=1024

# Hard memory limit (e.g., 512m, 1g, 2g)
INFRA_MEM_LIMIT=1g

# Reserved memory that should always be available for the process
INFRA_MEM_RESERVE=256m
